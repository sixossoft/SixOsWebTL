@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

@* ── LEFT PANEL ── *@
<div class="auth-left">
    <div class="deco-c1"></div>
    <div class="deco-c2"></div>
    <div class="deco-c3"></div>

    <a class="auth-brand" href="/">
        <img src="/static/logo.svg" alt="SixOs Training" class="auth-logo-img" />
    </a>

    <div class="auth-hero">
        <div class="auth-eyebrow">
            <span class="dot"></span>
            Hệ thống đào tạo nội bộ
        </div>
        <h1>Tra cứu tài liệu<br><em>mọi lúc, mọi nơi</em></h1>
        <p class="auth-desc">
            Đăng nhập để truy cập kho video hướng dẫn, tài liệu PDF/Word và hỏi đáp
            trực tiếp với đội ngũ hỗ trợ SixOs.
        </p>
        <ul class="auth-feats">
            <li><span class="feat-dot"></span>Video hướng dẫn từng chức năng phần mềm</li>
            <li><span class="feat-dot"></span>Tài liệu cập nhật theo từng phiên bản</li>
            <li><span class="feat-dot"></span>Hỏi đáp và tra cứu nhanh theo từ khóa</li>
            <li><span class="feat-dot"></span>Phân quyền theo từng cơ sở khám chữa bệnh</li>
        </ul>
    </div>

    <div class="auth-stats">
        <div class="auth-stat">
            <div class="num">500+</div>
            <div class="lbl">Video hướng dẫn</div>
        </div>
        <div class="auth-stat">
            <div class="num">200+</div>
            <div class="lbl">Tài liệu tham khảo</div>
        </div>
        <div class="auth-stat">
            <div class="num">50+</div>
            <div class="lbl">Phòng khám</div>
        </div>
    </div>
</div>

@* ── RIGHT PANEL ── *@
<div class="auth-right">
    <div class="auth-card">
        <div class="card-head">
            <div class="card-title">Đăng nhập</div>
            <div class="card-sub">Nhập thông tin tài khoản được phòng khám cấp</div>
        </div>

        @* Hiện lỗi nếu có *@
        @if (ViewBag.Error != null)
        {
            <div class="alert-error">
                <svg viewBox="0 0 20 20"><path d="M10 2a8 8 0 100 16A8 8 0 0010 2zm0 4a1 1 0 011 1v4a1 1 0 01-2 0V7a1 1 0 011-1zm0 8a1 1 0 100-2 1 1 0 000 2z" /></svg>
                <span>@ViewBag.Error</span>
            </div>
        }

        <form method="post" action="/Account/Login" onsubmit="return handleSubmit(this, document.getElementById('btnLogin'))">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
            <div class="form-group">
                <label class="form-label" for="tenTK">Tên tài khoản</label>
                <div class="input-wrap">
                    <span class="input-icon" style="margin-top: 4px;">
                        <svg viewBox="0 0 20 20"><path d="M10 2a4 4 0 100 8 4 4 0 000-8zm-7 14c0-3.314 3.134-6 7-6s7 2.686 7 6H3z" /></svg>
                    </span>
                    <input class="form-control @(ViewBag.Error != null ? "is-invalid" : "")"
                           type="text" id="tenTK" name="tenTK"
                           placeholder="vd: nva123"
                           value="@ViewBag.TenTK"
                           autocomplete="username" autofocus required />
                </div>
            </div>
            <div class="form-group">
                <label class="form-label" for="matKhau">Mật khẩu</label>
                <div class="input-wrap">
                    <span class="input-icon" style="margin-top: 4px;">
                        <svg viewBox="0 0 20 20"><path d="M7 9V7a5 5 0 0110 0v2h1a1 1 0 011 1v7a1 1 0 01-1 1H4a1 1 0 01-1-1v-7a1 1 0 011-1h3zm2 0h4V7a2 2 0 00-4 0v2z" /></svg>
                    </span>
                    <input class="form-control has-toggle @(ViewBag.Error != null ? "is-invalid" : "")"
                           type="password" id="matKhau" name="matKhau"
                           placeholder="••••••••"
                           autocomplete="current-password" required />
                    <button type="button" class="toggle-pw" onclick="togglePassword(this)" aria-label="Hiện/ẩn mật khẩu">
                        <svg class="eye-off" viewBox="0 0 20 20" fill="currentColor">
                            <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
                            <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />
                        </svg>
                        <svg class="eye-on" style="display:none" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M3.707 2.293a1 1 0 00-1.414 1.414l14 14a1 1 0 001.414-1.414l-1.473-1.473A10.014 10.014 0 0019.542 10C18.268 5.943 14.478 3 10 3a9.958 9.958 0 00-4.512 1.074l-1.78-1.781zm4.261 4.26l1.514 1.515a2.003 2.003 0 012.45 2.45l1.514 1.514a4 4 0 00-5.478-5.478z" clip-rule="evenodd" />
                            <path d="M12.454 16.697L9.75 13.992a4 4 0 01-3.742-3.741L2.335 6.578A9.98 9.98 0 00.458 10c1.274 4.057 5.064 7 9.542 7 .847 0 1.669-.105 2.454-.303z" />
                        </svg>
                    </button>
                </div>
            </div>
            <div class="form-check">
                <input type="checkbox" id="rememberMe" name="rememberMe" value="true" />
                <label for="rememberMe">Ghi nhớ đăng nhập</label>
            </div>
            <button type="submit" class="btn-submit" id="btnLogin">
                <span class="btn-spinner"></span>
                <span class="btn-text" style="display:flex;align-items:center;gap:8px;">
                    <svg viewBox="0 0 20 20"><path d="M3 10a7 7 0 1114 0A7 7 0 013 10zm9-1H8a1 1 0 000 2h4v2l3-3-3-3v2z" /></svg>
                    Đăng nhập
                </span>
            </button>
        </form>

        <div class="card-foot">
            <span>Chưa có tài khoản?</span>
            <a href="#">Liên hệ quản trị viên</a>
        </div>
    </div>
</div>
