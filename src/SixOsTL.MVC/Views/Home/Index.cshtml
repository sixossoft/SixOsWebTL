@{
    ViewData["Title"] = "Trang chủ";
    Layout = "~/Views/Shared/_LandingLayout.cshtml";
}

@* ══════════════════════════════════════════════════════════
   HERO
══════════════════════════════════════════════════════════ *@
<section class="hero">
    <div class="hero-dots"></div>
    <div class="hero-panel"></div>
    <div class="hero-circle-1"></div>
    <div class="hero-circle-2"></div>
    <div class="hero-bar"></div>

    <div class="hero-inner">
        <div class="hero-left">
            <div class="hero-eyebrow">
                <span class="dot"></span>
                Hệ thống đào tạo nội bộ
            </div>
            <h1>
                Tài liệu &amp; Video<br>
                hướng dẫn<br><em>chuyên sâu</em><br>
                phần mềm SixOs
            </h1>
            <ul class="hero-bullets">
                <li>Tuân thủ đúng quy trình nghiệp vụ từng cơ sở khám chữa bệnh</li>
                <li>Video &amp; tài liệu cập nhật liên tục theo phiên bản phần mềm</li>
                <li>Tra cứu nhanh, hỏi đáp trực tiếp với đội ngũ hỗ trợ</li>
            </ul>
            <div class="hero-cta">
                <a class="btn-primary" href="/Account/Login">Đăng nhập hệ thống</a>
                <a class="btn-ghost" href="#tieu-chi">Tìm hiểu thêm</a>
            </div>
        </div>

        <div class="hero-visual">
            <div class="hero-img-frame">
                <img src="~/static/banner1.jfif" class="hero-slide active" alt="Màn hình hệ thống đào tạo SixOs 1" />
                <img src="~/static/banner2.jfif" class="hero-slide" alt="Màn hình hệ thống đào tạo SixOs 2" />
            </div>
        </div>
    </div>
</section>

@* ══ STATS ══ *@
<div class="stats">
    <div class="stats-inner" data-stagger>
        <div class="stat-item">
            <div class="stat-num">500+</div>
            <div class="stat-label">Video hướng dẫn</div>
        </div>
        <div class="stat-item">
            <div class="stat-num">200+</div>
            <div class="stat-label">Tài liệu PDF / Word</div>
        </div>
        <div class="stat-item">
            <div class="stat-num">50+</div>
            <div class="stat-label">Phòng khám đang dùng</div>
        </div>
        <div class="stat-item">
            <div class="stat-num">24/7</div>
            <div class="stat-label">Truy cập mọi lúc mọi nơi</div>
        </div>
    </div>
</div>

@* ══════════════════════════════════════════════════════════
   TIÊU CHÍ PHÁT TRIỂN
══════════════════════════════════════════════════════════ *@
<section class="criteria" id="tieu-chi">
    <div class="section-inner">
        <div class="section-header" data-reveal>
            <span class="section-tag tag-light">Tiêu chí phát triển</span>
            <h2 class="h2-dark">Xây dựng trên những nguyên tắc vững chắc</h2>
            <p class="p-muted">Mỗi tính năng được thiết kế theo tiêu chí rõ ràng, đảm bảo phục vụ tốt nhất cho người dùng y tế.</p>
        </div>
        <div class="criteria-grid" data-row-stagger>

            <div class="criteria-card" style="--accent:#1565C0;">
                <div class="criteria-icon" style="background:#E3F2FD;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#1565C0" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2L2 7l10 5 10-5-10-5z" />
                        <path d="M2 17l10 5 10-5" />
                        <path d="M2 12l10 5 10-5" />
                    </svg>
                </div>
                <h3>Dễ mở rộng</h3>
                <p>Kiến trúc linh hoạt, tích hợp thêm chức năng mới hoặc kết nối hệ thống HIS hiện có của phòng khám.</p>
            </div>

            <div class="criteria-card" style="--accent:#0288D1;">
                <div class="criteria-icon" style="background:#E1F5FE;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#0288D1" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10" />
                        <path d="M12 8v4l3 3" />
                    </svg>
                </div>
                <h3>Cập nhật liên tục</h3>
                <p>Nội dung đồng bộ ngay khi phần mềm ra phiên bản mới, người dùng luôn có tài liệu phù hợp.</p>
            </div>

            <div class="criteria-card" style="--accent:#1E40AF;">
                <div class="criteria-icon" style="background:#E8F0FE;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#1E40AF" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="11" width="18" height="11" rx="2" />
                        <path d="M7 11V7a5 5 0 0110 0v4" />
                    </svg>
                </div>
                <h3>Bảo mật dữ liệu</h3>
                <p>Xác thực tài khoản theo từng cơ sở y tế, kiểm soát quyền truy cập chặt chẽ, thông tin nội bộ an toàn.</p>
            </div>

            <div class="criteria-card" style="--accent:#0277BD;">
                <div class="criteria-icon" style="background:#E1F5FE;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#0277BD" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z" />
                        <circle cx="12" cy="12" r="3" />
                    </svg>
                </div>
                <h3>Giao diện trực quan</h3>
                <p>Thiết kế khoa học, tìm kiếm nhanh theo từ khóa, phân loại theo chức năng — không cần hướng dẫn vẫn dùng được.</p>
            </div>

            <div class="criteria-card" style="--accent:#0284C7;">
                <div class="criteria-icon" style="background:#F0F9FF;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#0284C7" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" />
                    </svg>
                </div>
                <h3>Hỏi đáp tức thì</h3>
                <p>Người dùng đặt câu hỏi ngay trên từng chức năng, đội ngũ hỗ trợ phản hồi nhanh và lưu lại để tham khảo.</p>
            </div>

            <div class="criteria-card" style="--accent:#0D47A1;">
                <div class="criteria-icon" style="background:#E3F2FD;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#0D47A1" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                    </svg>
                </div>
                <h3>Tuân thủ quy định</h3>
                <p>Nội dung biên soạn bám sát quy định Bộ Y Tế hiện hành và quy trình nghiệp vụ chuẩn của từng loại cơ sở.</p>
            </div>

        </div>
    </div>
</section>

@* ══════════════════════════════════════════════════════════
   CÁCH SỬ DỤNG
══════════════════════════════════════════════════════════ *@
<section class="how" id="cach-dung">
    <div class="section-inner">
        <div class="section-header" data-reveal>
            <span class="section-tag tag-ice">Cách sử dụng</span>
            <h2 class="h2-dark">Bắt đầu chỉ trong 3 bước</h2>
            <p class="p-muted">Không cần cài đặt, không cần cấu hình — truy cập trực tiếp từ trình duyệt.</p>
        </div>
        <div class="steps" data-stagger>
            <div class="step">
                <div class="step-num step-1">1</div>
                <h3>Đăng nhập tài khoản</h3>
                <p>Dùng tài khoản được phòng khám cấp. Đăng nhập nhanh, không cần email xác thực.</p>
            </div>
            <div class="step">
                <div class="step-num step-2">2</div>
                <h3>Chọn chức năng cần học</h3>
                <p>Duyệt theo sản phẩm hoặc tìm kiếm theo từ khóa để tìm đúng tài liệu bạn cần.</p>
            </div>
            <div class="step">
                <div class="step-num step-3">3</div>
                <h3>Xem video &amp; tải tài liệu</h3>
                <p>Xem video ngay trên trình duyệt hoặc tải PDF/Word về để tham khảo offline.</p>
            </div>
        </div>
    </div>
</section>

@* ══════════════════════════════════════════════════════════
   TÍNH NĂNG
══════════════════════════════════════════════════════════ *@
<section class="features" id="tinh-nang">
    <div class="section-inner">
        <div class="section-header" data-reveal>
            <span class="section-tag tag-sky">Tính năng</span>
            <h2 class="h2-light">Đầy đủ công cụ cho đội ngũ y tế</h2>
            <p class="p-faded">Từ xem tài liệu đến quản lý nội dung, mọi thứ trong một nền tảng.</p>
        </div>
        <div class="features-grid" data-row-stagger>

            <div class="feat-card">
                <div class="feat-icon" style="background:rgba(8,145,178,.18);">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#40C4FF" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <polygon points="5 3 19 12 5 21 5 3" />
                    </svg>
                </div>
                <h3>Xem video trực tuyến</h3>
                <p>Phát video hướng dẫn ngay trên trình duyệt, không cần tải về, tốc độ stream ổn định.</p>
            </div>

            <div class="feat-card">
                <div class="feat-icon" style="background:rgba(56,189,248,.12);">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#90CAF9" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
                        <polyline points="14 2 14 8 20 8" />
                        <line x1="12" y1="18" x2="12" y2="12" />
                        <polyline points="9 15 12 18 15 15" />
                    </svg>
                </div>
                <h3>Tải tài liệu PDF / Word</h3>
                <p>Tải về để đọc offline, in ấn hoặc chia sẻ nội bộ trong ca trực.</p>
            </div>

            <div class="feat-card">
                <div class="feat-icon" style="background:rgba(147,197,253,.12);">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#90CAF9" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8" />
                        <line x1="21" y1="21" x2="16.65" y2="16.65" />
                    </svg>
                </div>
                <h3>Tìm kiếm theo từ khóa</h3>
                <p>Tìm đúng nội dung cần tìm trong vài giây với bộ tìm kiếm toàn văn theo tên và keyword.</p>
            </div>

            <div class="feat-card">
                <div class="feat-icon" style="background:rgba(103,232,249,.1);">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#4FC3F7" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" />
                    </svg>
                </div>
                <h3>Hỏi đáp theo chức năng</h3>
                <p>Đặt câu hỏi trực tiếp trên từng chức năng, nhận câu trả lời từ đội ngũ hỗ trợ SixOs.</p>
            </div>

            <div class="feat-card">
                <div class="feat-icon" style="background:rgba(186,230,253,.1);">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#81D4FA" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 00-3-3.87" />
                        <path d="M16 3.13a4 4 0 010 7.75" />
                    </svg>
                </div>
                <h3>Quản lý người dùng</h3>
                <p>Admin kiểm soát tài khoản theo từng cơ sở, phân quyền linh hoạt, giới hạn thời hạn truy cập.</p>
            </div>

            <div class="feat-card">
                <div class="feat-icon" style="background:rgba(165,243,252,.1);">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#B3E5FC" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="16 18 22 12 16 6" />
                        <polyline points="8 6 2 12 8 18" />
                    </svg>
                </div>
                <h3>Upload &amp; quản lý nội dung</h3>
                <p>Admin upload video, PDF, Word lên FTP ngay trong trang quản trị, sắp xếp theo sản phẩm và chức năng.</p>
            </div>

        </div>
    </div>
</section>

@* ══ CTA ══ *@
<section class="cta-section">
    <div class="section-inner">
        <div class="cta-box" data-reveal="scale">
            <h2>Sẵn sàng tra cứu tài liệu?</h2>
            <p>Đăng nhập bằng tài khoản được phòng khám cấp để truy cập đầy đủ video hướng dẫn và tài liệu chuyên sâu.</p>
            <a class="btn-primary-dark" href="/Account/Login">Đăng nhập ngay</a>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const slides = document.querySelectorAll('.hero-slide');
            let currentSlide = 0;
            const slideInterval = 5000;
            function nextSlide() {
                slides[currentSlide].classList.remove('active');
                currentSlide = (currentSlide + 1) % slides.length;
                slides[currentSlide].classList.add('active');
            }
            if (slides.length > 1) {
                setInterval(nextSlide, slideInterval);
            }
        });
    </script>
}